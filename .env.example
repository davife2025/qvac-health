# ─── Supabase (metadata only — NO health content stored in cloud) ─────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── API server ───────────────────────────────────────────────────────────────
API_PORT=3001
API_HOST=0.0.0.0

# Private API URL for Next.js server-side rewrites (not baked into client bundle)
API_URL=http://localhost:3001

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# ─── QVAC model cache ─────────────────────────────────────────────────────────
QVAC_MODEL_CACHE_DIR=.qvac-models

# ─── Web app public vars (baked into client bundle) ───────────────────────────

# Public-facing site URL — used by auth callback redirect.
# In production set to your actual domain: https://your-app.com
# In local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
